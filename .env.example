# --- Public (exposed to the browser) ------------------------------------- #
NEXT_PUBLIC_SITE_URL=https://fentriq.app
# Cal.com booking slug, e.g. fentriq/discovery
NEXT_PUBLIC_CALCOM_LINK=fentriq/discovery
# Booking origin: https://cal.eu for EU-region accounts, https://cal.com otherwise
NEXT_PUBLIC_CALCOM_ORIGIN=https://cal.eu
# WhatsApp number in E.164 without "+", e.g. 393331234567
NEXT_PUBLIC_WHATSAPP=393000000000
# Plausible domain — leave empty to disable analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=fentriq.app

# --- Server-only (never exposed) ----------------------------------------- #
# n8n webhook that receives every lead (the dogfooded automation)
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/fentriq-lead
# Resend — fallback email delivery if the webhook is down
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=info@fentriq.app
LEAD_EMAIL=you@fentriq.app

# AI chat assistant (OpenAI). Without a key the chat widget shows a fallback.
OPENAI_API_KEY=sk-xxxxxxxx
# Optional model override (default: gpt-4o-mini — cheap and fast)
OPENAI_MODEL=gpt-4o-mini
